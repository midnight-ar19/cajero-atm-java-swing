<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="com.mycompany.cajeroautomatico.logica.Movimiento" table="movimientos">
        <id name="id" column="id" type="int">
            <generator class="native"/>
        </id>
        <property name="tipo" column="tipo_movimiento" type="string"/>
        <property name="monto" column="monto" type="double" not-null="true"/>
        <property name="fechaHora" column="fecha_hora" type="java.time.LocalDateTime" not-null="true"/>
        
        <many-to-one name="usuario" column="usuario_id" not-null="true" 
            class="com.mycompany.cajeroautomatico.logica.Usuario"/>
    </class>
</hibernate-mapping>