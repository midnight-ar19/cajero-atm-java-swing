<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="com.mycompany.cajeroautomatico.logica.Usuario" table="usuarios">
        <id name="id" column="id" type="int">
            <generator class="native"/>
        </id>
        <property name="nombre" column="nombre" type="string" not-null="true"/>
        <property name="apellido" column="apellido" type="string" not-null="true"/>
        <property name="numeroCuenta" column="numero_cuenta" type="string" not-null="true"/>
        <property name="numeroTarjeta" column="numero_tarjeta" type="string" not-null="true"/>
        <property name="saldo" column="saldo" type="double" not-null="true"/>
        <property name="pin" column="pin" type="string" not-null="true"/>
        <property name="tipoCuenta" column="tipo_cuenta" type="string"/>
        
        <bag name="movimientos" cascade="all,delete-orphan" inverse="true">
            <key column="usuario_id"/>
            <one-to-many class="com.mycompany.cajeroautomatico.logica.Movimiento"/>
        </bag>
    </class>
</hibernate-mapping>